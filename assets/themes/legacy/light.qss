/* 
  Modern Light Design for Ollama Desktop Chat
  Based on static/css/styles.css (Light Theme)
*/

QMainWindow {
    background-color: #f7f8ff;
}

#chatWidget {
    background: qradialgradient(cx:0.2, cy:0.1, radius:1.2, fx:0.2, fy:0.1, 
                                stop:0 rgba(124, 58, 237, 0.1), 
                                stop:0.6 transparent,
                                stop:1.0 #f7f8ff);
}

#chatView {
    background-color: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 22px;
    color: #0c1020;
    font-size: 14px;
    padding: 15px;
    selection-background-color: rgba(124, 58, 237, 0.2);
}

#inputContainer {
    background-color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 22px;
    margin-top: 10px;
}

#chatInput {
    background: transparent;
    border: none;
    color: #0c1020;
    font-size: 15px;
    padding: 10px;
}

#sendButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
                                stop:0 rgba(124, 58, 237, 0.7), 
                                stop:1 rgba(56, 189, 248, 0.6));
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 16px;
    color: white;
    font-weight: bold;
    font-size: 14px;
    padding: 8px 20px;
    margin: 5px;
}

#sendButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
                                stop:0 rgba(124, 58, 237, 0.85), 
                                stop:1 rgba(56, 189, 248, 0.75));
}

QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: rgba(0, 0, 0, 0.05);
    min-height: 40px;
    border-radius: 5px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(0, 0, 0, 0.1);
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: transparent;
}

QToolBar {
    background-color: rgba(255, 255, 255, 0.35);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    spacing: 10px;
    padding: 5px;
}

QToolButton {
    background-color: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 10px;
    padding: 5px;
}
